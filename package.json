{
  "name": "arckia",
  "version": "0.4.0",
  "description": "Cross-platform senior architect agent with persistent memory (VISION / ROADMAP / ADR)",
  "license": "MIT",
  "bin": {
    "arckia": "scripts/arckia"
  },
